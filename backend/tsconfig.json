{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@jukebox/shared": ["../shared/types/index"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/**/__tests__", "src/**/*.test.ts"]
}
